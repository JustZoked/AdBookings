# ============================================================
# ADSEMBLE BOOKINGS — Environment Variables
# Copy to .env and fill in the values before running.
# ============================================================

# ---------------------------------------------------------------
# App
# ---------------------------------------------------------------
DOMAIN=reservas.adsemble.do
APP_URL=https://reservas.adsemble.do        # Used to build magic links in emails
CONTACT_EMAIL=m.molina@adsemble.do          # TEMP during testing; change to recepcion@adsemble.do in prod
ADMIN_NOTIFICATION_EMAIL=m.molina@adsemble.do  # TEMP; receives new booking notifications + action buttons
TZ=America/Santo_Domingo

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
DATABASE_URL=postgresql://adsemble:CHANGEME@db:5432/adsemble
POSTGRES_USER=adsemble
POSTGRES_PASSWORD=CHANGEME                  # Change to a strong password
POSTGRES_DB=adsemble

# ---------------------------------------------------------------
# Magic links (approve/reject/retry from email)
# Generate with: openssl rand -base64 48
# ---------------------------------------------------------------
BOOKING_ACTION_SECRET=                      # REQUIRED — at least 32 chars
ACTION_TOKEN_TTL_DAYS=7                     # How long action links stay valid

# ---------------------------------------------------------------
# Email driver
# ---------------------------------------------------------------
MAIL_DRIVER=graph                           # graph | smtp

# ---------------------------------------------------------------
# Microsoft Graph (required when MAIL_DRIVER=graph OR CALENDAR_ENABLED=true)
# App registration in Entra ID with Mail.Send + Calendars.ReadWrite (Application permissions)
# ---------------------------------------------------------------
MS_TENANT_ID=                               # Directory (tenant) ID
MS_CLIENT_ID=                               # Application (client) ID
MS_CLIENT_SECRET=                           # Client secret VALUE (not the ID)
MS_SENDER_EMAIL=m.molina@adsemble.do        # TEMP; mailbox that sends emails + creates calendar events
                                            # Change to recepcion@adsemble.do in production

# ---------------------------------------------------------------
# Calendar integration (Logitech screens via Exchange resource mailboxes)
# ---------------------------------------------------------------
CALENDAR_ENABLED=true                       # true in prod; false in dev/demos (uses noop driver)

# ---------------------------------------------------------------
# SMTP fallback (used when MAIL_DRIVER=smtp)
# ---------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Adsemble Bookings <m.molina@adsemble.do>"  # TEMP; change in prod

# ---------------------------------------------------------------
# Pricing rules
# ---------------------------------------------------------------
NIGHT_SURCHARGE_START_HOUR=18              # Hour (local time) when night surcharge starts
NIGHT_SURCHARGE_PERCENT=30                 # Night surcharge percentage
WEEKEND_SURCHARGE_PERCENT=30              # Weekend surcharge percentage (Sat + Sun)
BOOKING_BUFFER_MINUTES=15                  # Buffer minutes between reservations
