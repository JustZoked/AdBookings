generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id               String        @id @default(cuid())
  name             String        @unique
  slug             String        @unique
  description      String        @db.Text
  basePricePerHour Decimal       @db.Decimal(10, 2)
  minAdvanceHours  Int           @default(24)
  roomEmail        String
  capacity         Int?
  isActive         Boolean       @default(true)
  amenities        Amenity[]
  images           RoomImage[]
  reservations     Reservation[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("rooms")
}

model Amenity {
  id        String  @id @default(cuid())
  roomId    String
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  label     String
  price     Decimal @db.Decimal(10, 2)
  sortOrder Int     @default(0)

  @@map("amenities")
}

model RoomImage {
  id        String @id @default(cuid())
  roomId    String
  room      Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int    @default(0)

  @@map("room_images")
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Reservation {
  id                  String            @id @default(cuid())
  roomId              String
  room                Room              @relation(fields: [roomId], references: [id])
  startAt             DateTime
  endAt               DateTime
  requesterName       String
  requesterEmail      String
  activity            String
  calculatedPrice     Decimal           @db.Decimal(10, 2)
  priceBreakdown      Json
  selectedAmenityIds  String[]
  status              ReservationStatus @default(PENDING)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  approvedAt          DateTime?
  rejectedAt          DateTime?
  adminNotes          String?           @db.Text
  emailSent           Boolean           @default(false)
  emailLastError      String?           @db.Text
  roomEmailSnapshot   String?
  graphEventId        String?
  graphEventLastError String?           @db.Text

  @@map("reservations")
}
